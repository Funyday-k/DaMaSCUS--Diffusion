.DS_Store

# ─── 大型数据文件（不上传到仓库）────────────────────────────────
data/
parsed_transitions.npz

# ─── 模型权重（存放在 checkpoints/ 下，文件过大不纳入版本控制）─
checkpoints/*.pth
checkpoints/*.pt
checkpoints/*.ckpt
# 兼容旧版本直接放在根目录的权重
*.pth
*.pt
*.ckpt

# ─── 输出目录（PNG 图片和小型结果纳入版本控制；大文件不跟踪）──
# outputs/ 中的 PNG 已自动被 git 跟踪
# 以下输出 npz 文件体积较大，忽略
outputs/trajectory_validation_results.npz

# ─── Python 缓存 ────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ─── 虚拟环境 ───────────────────────────────────────────────────
.venv/
venv/
env/

# ─── 日志与临时文件 ─────────────────────────────────────────────
logs/
*.log
